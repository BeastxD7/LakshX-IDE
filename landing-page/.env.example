# Copy this file to .env.local and fill in real values. Never commit
# .env.local (it's gitignored) — only this .env.example template is tracked.

# --- Supabase (auth + hosted-model usage/budget/subscription tables) ---
# All three: Supabase dashboard -> Project Settings -> Data API / API Keys
# (https://supabase.com/dashboard/project/_/settings/api-keys)
SUPABASE_URL="https://<your-project-ref>.supabase.co"
# The anon/publishable key -- safe-ish (RLS still applies) but still kept
# server-side only here since this app has no client-side Supabase usage.
SUPABASE_ANON_KEY="[SENSITIVE]"
# The service_role key -- bypasses Row Level Security entirely. NEVER
# expose this to a browser bundle; only used in server-side admin/route
# code (lib/supabase/admin.ts) after independently verifying the caller.
SUPABASE_SERVICE_ROLE_KEY="[SENSITIVE]"

# --- Azure OpenAI (the hosted "lakshx" free-tier model, gpt-5-mini) ---
# Azure Portal -> your Azure OpenAI / AI Foundry resource -> "Keys and
# Endpoint" blade for AZURE_OPENAI_API_KEY + AZURE_OPENAI_ENDPOINT.
# AZURE_OPENAI_DEPLOYMENT is the deployment NAME you chose when you
# deployed the model in Azure AI Foundry's "Deployments" tab (not the
# underlying model name itself, e.g. could be "gpt-5-mini" or anything
# else you named it at deploy time).
AZURE_OPENAI_API_KEY="[SENSITIVE]"
AZURE_OPENAI_ENDPOINT="https://<your-resource-name>.openai.azure.com/openai/v1"
AZURE_OPENAI_DEPLOYMENT="gpt-5-mini"

# --- Vercel Blob (hosts the IDE download artifacts: .dmg/.exe/.deb) ---
# Vercel dashboard -> Storage -> the "koder-downloads" Blob store ->
# .env.local tab (or `vercel env pull` if the store is already linked to
# this project). Only needed for uploading new builds
# (scripts/upload via `vercel blob put`) -- not read by any app route.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# --- Dodo Payments (LakshX Pro subscription billing, test mode) ---
# Dodo dashboard (test mode toggle on) -> Developer / API Keys section.
DODO_API_KEY="[SENSITIVE]"
# The product id for "LakshX Pro" ($15/mo recurring) -- Dodo dashboard ->
# Products, or `client.products.list()` -- looks like "pdt_xxxxxxxxxxxx".
DODO_PRO_PRODUCT_ID="pdt_..."
# Dodo dashboard -> Webhooks -> create one pointing at
# https://<your-domain>/api/webhooks/dodo, subscribed to at least:
# subscription.active, subscription.renewed, subscription.on_hold,
# subscription.cancelled, subscription.failed, subscription.expired.
# The signing secret is shown once when you create/view that webhook.
DODO_WEBHOOK_SECRET="whsec_..."
