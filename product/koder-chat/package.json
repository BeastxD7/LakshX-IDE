{
  "name": "koder-chat",
  "displayName": "Koder Agent",
  "description": "Koder's agent panel — talks to the Koder Agent Runtime over ACP.",
  "version": "0.0.1",
  "publisher": "koder",
  "license": "MIT",
  "engines": { "vscode": "^1.128.0" },
  "main": "./extension.js",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "koder",
          "title": "Koder",
          "icon": "media/koder.svg"
        }
      ]
    },
    "views": {
      "koder": [
        {
          "type": "webview",
          "id": "koder.agentView",
          "name": "Agent",
          "icon": "media/koder.svg"
        }
      ]
    },
    "commands": [
      { "command": "koder.openAgent", "title": "Koder: Open Agent", "icon": "media/koder.svg" },
      { "command": "koder.newChat", "title": "Koder: New Chat", "icon": "$(add)" },
      { "command": "koder.openProviderSettings", "title": "Koder: Configure AI Providers (BYOK)", "icon": "$(gear)" }
    ],
    "keybindings": [
      { "command": "koder.openAgent", "key": "ctrl+l", "mac": "cmd+l" }
    ],
    "menus": {
      "view/title": [
        { "command": "koder.newChat", "when": "view == koder.agentView", "group": "navigation@1" },
        { "command": "koder.openProviderSettings", "when": "view == koder.agentView", "group": "navigation@2" }
      ],
      "editor/title": [
        { "command": "koder.openAgent", "group": "navigation@100" }
      ]
    },
    "configuration": {
      "title": "Koder Agent",
      "properties": {
        "koder.agent.command": {
          "type": "string",
          "default": "",
          "description": "Command to launch the Koder Agent Runtime (ACP over stdio). Empty = auto-detect the bundled runtime."
        }
      }
    }
  }
}
